# ─────────────────────────────────────────────────────
# Provider 선택 — 실시간 STT+번역을 어느 API로 할지.
#   google  : Cloud Speech-to-Text + Cloud Translation (+ Gemini for assist/reconstruct)
#   openai  : OpenAI Realtime API (+ Chat Completions for reconstruct)
# RECONSTRUCT_PROVIDER 는 생략 시 REALTIME_PROVIDER 를 그대로 따른다.
# ─────────────────────────────────────────────────────
REALTIME_PROVIDER=google
RECONSTRUCT_PROVIDER=google

REALTIME_GATEWAY_SECRET=use-a-32+ char-shared-secret-with-web

SUPABASE_URL=https://YOUR.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_jwt

# ─────────────────────────────────────────────────────
# Google 자격 — REALTIME_PROVIDER=google 일 때 필요
# ─────────────────────────────────────────────────────
# (a) STT + Translation: 서비스 계정 JSON 을 통째로 stringify 해서 붙여넣기.
#     로컬에서는 GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json 만 주면 SDK 기본 동작.
GOOGLE_SERVICE_ACCOUNT_JSON=
# (b) Gemini: Google AI Studio API key.
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────────────────
# OpenAI 자격 — REALTIME_PROVIDER=openai 일 때 필요 (google 이면 비워둬도 무방)
# ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# Optional but recommended (게스트 트라이얼 타이머용)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info
TRIAL_DECREMENT_INTERVAL_MS=5000

# A-2 자료 파싱 워커
PARSER_POLL_INTERVAL_MS=5000
PARSER_STORAGE_BUCKET=uploads

# A-3 사후 복원 워커
RECONSTRUCT_POLL_INTERVAL_MS=10000
