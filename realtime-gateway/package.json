{
  "name": "lucid-realtime-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WebSocket bridge between browser <-> OpenAI Realtime. Validates ephemeral JWTs, enforces guest trial countdown, persists transcripts to Supabase.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@google-cloud/translate": "^9.3.0",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/redis": "^1.34.0",
    "fastify": "^4.28.1",
    "jose": "^5.9.6",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.5.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
