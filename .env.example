# ─────────────────────────────────────────────────────
# Public (NEXT_PUBLIC_*) — 브라우저 노출 안전
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:8080/v1
# realtime-gateway WebSocket endpoint. browser → wss://...lucid-realtime-gateway.fly.dev/v1/stream
NEXT_PUBLIC_REALTIME_GATEWAY_URL=ws://localhost:8787/v1/stream
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────────────────
# Server-only secrets (절대 NEXT_PUBLIC_ prefix 금지)
# ─────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...
REALTIME_GATEWAY_SECRET=please-change-me-32-bytes-hex
REALTIME_TOKEN_TTL_S=900
# Server-side fallback if NEXT_PUBLIC_REALTIME_GATEWAY_URL is missing
REALTIME_GATEWAY_URL=ws://localhost:8787/v1/stream
INVITE_CODES="alpha-001 alpha-002"

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

UPSTASH_REDIS_REST_URL=https://YOUR.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

SENTRY_DSN=
RESEND_API_KEY=
LOG_LEVEL=info

# Trial / limits
GUEST_TRIAL_SECONDS=600
GUEST_TRIAL_WARN_SECONDS=120
GUEST_RATE_LIMIT_PER_HOUR=10
# 브라우저에도 노출되는 '체험 총 시간' — 시계 UI 가 사용. 서버의 GUEST_TRIAL_SECONDS 와 반드시 일치시킬 것.
NEXT_PUBLIC_GUEST_TRIAL_SECONDS=600
MAX_ASSET_SIZE_MB=20
MAX_ASSETS_PER_SESSION_MB=50
NEXT_PUBLIC_MAX_ASSET_SIZE_MB=20
NEXT_PUBLIC_MAX_ASSETS_PER_SESSION_MB=50

# 공개 베타·상용 전환 시 true 로 켜면 게스트 체험 진입 차단 → /signup 으로 유도.
# 현재 테스트 단계에서는 false (비회원도 체험 가능).
REQUIRE_SIGNUP_FOR_TRIAL=false

# 월 예산 (원). /admin 랜딩이 "이번 달 추정 원가 / 예산" 을 계산해 50% / 80% / 100%
# 구간마다 배너 색을 바꿔 노출. 비워두면 배너 숨김. 실제 GCP Billing 경고와 별개인
# 앱 내부 가정값 기반 조기 경고.
BUDGET_MONTHLY_KRW=100000

# PIPA — 게스트 IP 는 원문 저장 금지. 서버 비밀 salt 로 SHA-256 해시.
# 프로덕션에서는 충분히 긴 랜덤 문자열 (≥32 bytes) 로 반드시 지정.
GUEST_IP_HASH_SALT=change-me-before-production
